// مخطط قاعدة البيانات — مُترجم من وثيقة Database Design (v1)
// القاعدة: doctorate_platform على Cluster0 — قاعدة mylibrary لا تُلمس أبدًا
// ملاحظة: الفهرس النصي وفهارس TTL لا يدعمها Prisma — ينشئها سكريبت الاستيراد تلقائيًا

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ===== التعدادات =====

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ExamType {
  general
  specialty
}

enum Difficulty {
  easy
  medium
  hard
}

enum TopicStatus {
  published
  draft
  needs_completion
}

enum FileKind {
  exam_pdf
  solution_pdf
}

enum ReportType {
  wrong_content
  broken_file
  wrong_classification
  other
}

enum ReportStatus {
  open
  resolved
  rejected
}

enum ContributionType {
  latex
  file
}

enum ContributionStatus {
  pending
  accepted
  rejected
  duplicate
}

enum ServiceKey {
  website
  search
  downloads
  auth
  database
  email
  storage
}

enum ServiceState {
  operational
  degraded
  down
}

enum StatusMode {
  manual
  auto
}

enum ChangeType {
  new
  improved
  fixed
}

enum SuccessStorySubmissionStatus {
  pending
  approved
  rejected
}

// ===== الأنواع المضمّنة (Embedded) =====

type Problem {
  problemNumber Int
  title         String
  difficulty    Difficulty @default(medium)
  tags          String[]
  statement     String // نص التمرين بصيغة LaTeX
  solution      String? // الحل بصيغة LaTeX (اختياري)
  remark        String? // ملاحظة إضافية (موجودة في بعض تمارين mylibrary)
  hasSolution   Boolean    @default(false)
}

type TopicFile {
  kind       FileKind
  url        String
  fileName   String
  sizeBytes  Int
  uploadedAt DateTime
}

type ChangelogItem {
  type   ChangeType
  textAr String
}

// ===== المجموعات =====

model University {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String  @unique
  nameAr String
  slug   String  @unique
  city   String?
  topics Topic[]

  @@map("universities")
}

model Specialty {
  id     String  @id @default(auto()) @map("_id") @db.ObjectId
  name   String  @unique
  nameAr String
  slug   String  @unique
  topics Topic[]

  @@map("specialties")
}

model Topic {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  legacyId        Int?        @unique // رقم الامتحان القديم من mylibrary (حقل examId)
  slug            String      @unique // مثال: blida-1-2025-general-03
  title           String
  examType        ExamType
  year            Int
  universityId    String      @db.ObjectId
  university      University  @relation(fields: [universityId], references: [id])
  specialtyId     String      @db.ObjectId
  specialty       Specialty   @relation(fields: [specialtyId], references: [id])
  source          String // النص الأصلي كما هو (يُعرض داخل جزيرة LTR)
  examNumber      Int?
  coefficient     Int?
  durationMinutes Int?
  examDate        DateTime?
  problems        Problem[]
  files           TopicFile[]
  favorites       Favorite[]
  status          TopicStatus @default(published)
  downloadCount   Int         @default(0)
  viewCount       Int         @default(0)
  latexReview     String? // pending | done | rejected — مراجعة تحسين LaTeX
  dupReview       String? // "checked" بعد التحقق اليدوي من المكررات
  polished        Json? // النسخة المحسّنة بانتظار موافقة الأدمين
  createdById     String?     @db.ObjectId
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([universityId, year, specialtyId])
  @@index([specialtyId, year])
  @@index([status])
  @@index([status, year(sort: Desc), examNumber]) // فهرس مطابق لفرز صفحة البحث
  @@map("topics")
}

model User {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  email          String         @unique
  name           String
  passwordHash   String?
  role           Role           @default(USER)
  userType       String?
  image          String?
  emailVerified  DateTime?
  points         Int            @default(0)
  lastSeenAt     DateTime?
  blocked        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  accounts       Account[]
  sessions       Session[]
  reports        Report[]
  contributions  Contribution[]
  favorites      Favorite[]

  @@map("users")
}

model Favorite {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  topicId   String   @db.ObjectId
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
  @@index([userId, createdAt(sort: Desc)]) // لترتيب المفضلة
  @@map("favorites")
}

model Contribution {
  id              String             @id @default(auto()) @map("_id") @db.ObjectId
  userId          String             @db.ObjectId
  user            User               @relation(fields: [userId], references: [id])
  type            ContributionType
  status          ContributionStatus @default(pending)
  // بيانات الموضوع المقترح
  universityId    String?            @db.ObjectId
  universityName  String?
  specialtyId     String?            @db.ObjectId
  specialtyName   String?
  year            Int?
  examType        ExamType?
  examNumber      Int?
  coefficient     Int?
  durationMinutes Int?
  title           String?
  source          String?
  problemsJson    String? // JSON للتمارين (LaTeX)
  fileUrl         String?
  fileName        String?
  fileSizeBytes   Int?
  filesJson       String? // JSON لقائمة الملفات المرفوعة [{url, fileName, sizeBytes}]
  // مراجعة المدير
  pointsAwarded   Int?
  handledById     String?            @db.ObjectId
  adminNote       String?
  createdTopicId  String?            @db.ObjectId
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([userId])
  @@map("contributions")
}

// نماذج Auth.js القياسية (الأسبوع 5)
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Report {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  topicId       String       @db.ObjectId
  problemNumber Int?
  userId        String       @db.ObjectId
  user          User         @relation(fields: [userId], references: [id])
  type          ReportType
  message       String
  status        ReportStatus @default(open)
  handledById   String?      @db.ObjectId
  createdAt     DateTime     @default(now())

  @@index([status])
  @@map("reports")
}

model Draft {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  formId    String // معرف النموذج، مثال: admin-topic-new
  data      Json
  savedAt   DateTime @default(now())
  expiresAt DateTime // فهرس TTL (30 يومًا) يُنشأ من سكريبت الاستيراد

  @@unique([userId, formId])
  @@map("drafts")
}

model ServiceStatus {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  key           ServiceKey   @unique
  labelAr       String
  state         ServiceState @default(operational)
  mode          StatusMode   @default(manual)
  lastCheckedAt DateTime?
  updatedById   String?      @db.ObjectId

  @@map("serviceStatuses")
}

model Incident {
  id                  String     @id @default(auto()) @map("_id") @db.ObjectId
  serviceKey          ServiceKey
  titleAr             String
  descriptionAr       String?
  startedAt           DateTime
  resolvedAt          DateTime? // المدة تُحسب ولا تُخزن
  notifiedSubscribers Boolean    @default(false)
  createdById         String?    @db.ObjectId

  @@index([startedAt])
  @@map("incidents")
}

model StatusSubscription {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  email            String   @unique
  unsubscribeToken String
  createdAt        DateTime @default(now())

  @@map("statusSubscriptions")
}

model ChangelogEntry {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  titleAr     String
  items       ChangelogItem[]
  publishedAt DateTime        @default(now())
  createdById String?         @db.ObjectId

  @@map("changelogEntries")
}

model ErrorLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  message   String
  stack     String?
  path      String?
  createdAt DateTime @default(now()) // فهرس TTL (90 يومًا) يُنشأ من سكريبت الاستيراد

  @@map("errorLogs")
}

// مفاتيح الذكاء الاصطناعي — تُدار من صفحة /admin/ai (كل مفتاح له مهمة)
model AiKey {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String // اسم وصفي
  baseUrl       String // مثال: https://api.mistral.ai/v1
  model         String // مثال: mistral-large-latest
  apiKey        String
  task          String // latex | duplicates | vision | general
  active        Boolean   @default(true)
  lastStatus    String? // ok | fail
  lastError     String?
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("ai_keys")
}

// تتبع تقدم المستخدم: المواضيع التي أنهى حلها (ميزة "تم الحل")
model TopicProgress {
  id      String   @id @default(auto()) @map("_id") @db.ObjectId
  userId  String   @db.ObjectId
  topicId String   @db.ObjectId
  doneAt  DateTime @default(now())

  @@unique([userId, topicId])
  @@index([userId, doneAt(sort: Desc)]) // لصفحة مراجعتي
  @@map("topic_progress")
}

// عدّادات عامة بسيطة — زيارات صفحة القهوة، نسخ حساب CCP...
model Counter {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value Int    @default(0)

  @@map("counters")
}

model SolutionSuggestion {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  topicId      String   @db.ObjectId
  problemIndex Int
  authorName   String?
  contentText  String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())

  @@index([topicId, problemIndex, status])
}
// ============================================
// أضف هذا الموديل إلى ملف prisma/schema.prisma
// ثم نفّذ:  npx prisma db push && npx prisma generate
// ============================================

model AiSetting {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  key          String   @unique // "reading_mode"
  enabled      Boolean  @default(false)
  baseUrl      String   @default("https://api.openai.com/v1") // أي مزود ��توافق مع OpenAI (OpenAI, Groq, DeepSeek, OpenRouter, Together...)
  apiKey       String   @default("")
  model        String   @default("gpt-4o-mini")
  systemPrompt String   @default("")
  temperature  Float    @default(0.3)
  maxTokens    Int      @default(2000)
  updatedAt    DateTime @updatedAt
}

// ===== تجارب الناجحين في الدكتوراه (يحررها المدير فقط) =====
model SuccessStory {
  id         String             @id @default(auto()) @map("_id") @db.ObjectId
  slug       String             @unique
  name       String?
  university String?
  year       Int?
  title      String
  excerpt    String
  story      String
  advice     String
  position   Int                @default(0)
  published  Boolean            @default(false)
  viewCount  Int                @default(0)
  likes      SuccessStoryLike[]
  views      SuccessStoryView[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([published, position])
  @@map("success_stories")
}

model SuccessStoryLike {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  storyId   String       @db.ObjectId
  visitorId String
  story     SuccessStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([storyId, visitorId])
  @@index([storyId])
  @@map("success_story_likes")
}

model SuccessStoryView {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  storyId   String       @db.ObjectId
  visitorId String
  story     SuccessStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([storyId, visitorId])
  @@index([storyId])
  @@map("success_story_views")
}

model SuccessStorySubmission {
  id         String                       @id @default(auto()) @map("_id") @db.ObjectId
  name       String?
  email      String?
  university String?
  year       Int?
  title      String
  excerpt    String
  story      String
  advice     String
  status     SuccessStorySubmissionStatus @default(pending)
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@map("success_story_submissions")
}

// ===== مقالات دليل الطالب =====
model Article {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  titleAr     String
  summary     String?  // مقتطف قصير يظهر في القائمة
  content     String   // محتوى Markdown + LaTeX
  position    Int      @default(0)  // ترتيب الظهور (الأصغر أولاً)
  published   Boolean  @default(false)
  createdById String?  @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, position])
  @@map("articles")
}
