# DocMath AI — Azure AI configuration
# أضف هذه الأسطر إلى ملف .env الموجود في مشروعك (لا تحذف الأسطر القديمة)
# NEVER commit .env to Git.

# === إجباري ===
AZURE_OPENAI_ENDPOINT=https://docmathdz-phi-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=PASTE_YOUR_KEY_HERE

# === وضع القراءة (Reading Mode) — DeepSeek فقط ===
AZURE_OPENAI_DEPLOYMENT=DeepSeek-V3.2
# اختياري: اسم صريح لـ DeepSeek (إن اختلف عن AZURE_OPENAI_DEPLOYMENT)
# AZURE_OPENAI_DEPLOYMENT_DEEPSEEK=DeepSeek-V3.2

# === الصفحة الرئيسية (Mathora) — Kimi فقط ===
# انشر Kimi في Azure Foundry ثم ضع اسم الـ deployment هنا
AZURE_OPENAI_DEPLOYMENT_KIMI=Kimi-K2.6

# === اختياري — نموذج رؤية للصور في وضع القراءة ===
# AZURE_OPENAI_DEPLOYMENT_VISION=

# === اختياري — الحدود اليومية لكل مستخدم ===
# AI_DAILY_MESSAGES=30
# AI_DAILY_IMAGES=5
# AI_DAILY_FILES=3
# AI_PER_MINUTE=6
# ASSISTANT_MESSAGES=50
# ASSISTANT_WINDOW_HOURS=4

# === محذوف — لا تستخدم Phi بعد الآن ===
# AZURE_OPENAI_DEPLOYMENT_FAST=
# AZURE_OPENAI_DEPLOYMENT_THINKING=
